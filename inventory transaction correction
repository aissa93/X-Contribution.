1- we have those SO details in inverntory transaction, so I started to correct it using the following query:
--✅ Step 1: Delete from InventTrans
DELETE IT
FROM InventTrans IT
JOIN InventTransOrigin ITO ON IT.InventTransOrigin = ITO.RecId
WHERE ITO.ReferenceCategory = 0
  AND IT.StatusIssue = 6
  AND( ITO.DataAreaId = 'oqat' OR  ITO.DataAreaId = 'RSAU' OR   ITO.DataAreaId = 'ROMN' OR  ITO.DataAreaId = 'ruae' OR  ITO.DataAreaId = 'rkwt' OR  ITO.DataAreaId = 'rbhr' )
  AND NOT EXISTS (
      SELECT 1
      FROM SalesTable ST
      WHERE ST.SalesId = ITO.ReferenceId
        AND ST.DataAreaId = ITO.DataAreaId
  );

--✅ Step 2: Delete from InventTransOrigin
DELETE ITO
FROM InventTransOrigin ITO
WHERE ITO.ReferenceCategory = 0
  AND( ITO.DataAreaId = 'oqat' OR  ITO.DataAreaId = 'RSAU' OR   ITO.DataAreaId = 'ROMN' OR  ITO.DataAreaId = 'ruae' OR  ITO.DataAreaId = 'rkwt' OR  ITO.DataAreaId = 'rbhr' )
  AND NOT EXISTS (
      SELECT 1
      FROM SalesTable ST
      WHERE ST.SalesId = ITO.ReferenceId
        AND ST.DataAreaId = ITO.DataAreaId
  )
  AND NOT EXISTS (
      SELECT 1
      FROM InventTrans IT
      WHERE IT.InventTransOrigin = ITO.RecId
  );
